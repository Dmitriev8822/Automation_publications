# Application
# Use prod for the real service after secrets are filled.
APP_ENV=prod
LOG_LEVEL=INFO

# Database
DATABASE_URL=sqlite:///./data/publications.db

# Scheduler
PUBLISH_INTERVAL_MINUTES=30

# OpenRouter
# Required for APP_ENV=prod.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Telegram
# Required for APP_ENV=prod. Copy TELEGRAM_BOT_TOKEN exactly from @BotFather: <bot_id>:<secret>.
# TELEGRAM_CHANNEL_ID is the target channel, for example @channel_name or -1001234567890.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# News and generation
NEWS_TOPIC=technology
NEWS_LANGUAGE=ru
POST_LANGUAGE=ru
MAX_NEWS_ITEMS=5
POST_STYLE=concise
POST_MAX_LENGTH=1000
INCLUDE_SOURCE_LINK=true
INCLUDE_HASHTAGS=true
ENABLE_IMAGE_GENERATION=false
