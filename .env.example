# Runtime mode: dev, test or prod
APP_ENV=dev
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./data/publications.db
PUBLISH_INTERVAL_MINUTES=30

# OpenRouter settings. OPENROUTER_API_KEY is required in prod.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Telegram settings. Both values are required in prod.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# News and post generation settings.
NEWS_TOPIC=technology
NEWS_LANGUAGE=ru
POST_LANGUAGE=ru
MAX_NEWS_ITEMS=5
POST_STYLE=concise
POST_MAX_LENGTH=1000
INCLUDE_SOURCE_LINK=true
INCLUDE_HASHTAGS=true
ENABLE_IMAGE_GENERATION=false
