# Application
# Use prod for the real service after secrets are filled.
APP_ENV=prod
LOG_LEVEL=INFO

# Database
DATABASE_URL=sqlite:///./data/publications.db

# Scheduler
PUBLISH_INTERVAL_MINUTES=30

# OpenRouter
# Required for APP_ENV=prod.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Telegram
# Required for APP_ENV=prod. TELEGRAM_CHANNEL_ID can be @channel_name or a numeric channel id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# News and generation
NEWS_TOPIC=technology
NEWS_LANGUAGE=ru
POST_LANGUAGE=ru
MAX_NEWS_ITEMS=5
POST_STYLE=concise
POST_MAX_LENGTH=1000
INCLUDE_SOURCE_LINK=true
INCLUDE_HASHTAGS=true
ENABLE_IMAGE_GENERATION=false
