# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=
OPENROUTER_IMAGE_MODEL=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# News and generation
NEWS_TOPIC=
NEWS_LANGUAGE=ru
MAX_NEWS_ITEMS=10
POST_LANGUAGE=ru
POST_STYLE=informative
POST_MAX_LENGTH=1000
INCLUDE_SOURCE_LINK=true
INCLUDE_HASHTAGS=true
ENABLE_IMAGE_GENERATION=false

# Database
DATABASE_URL=sqlite:///./data/publications.db

# Scheduler
PUBLISH_INTERVAL_MINUTES=30

# Application
LOG_LEVEL=INFO
APP_ENV=dev
