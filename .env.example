# Application
# Use prod for the real service after secrets are filled.
APP_ENV=prod
LOG_LEVEL=INFO

# Database
DATABASE_URL=sqlite:///./data/publications.db

# Scheduler
# Content-plan due items are checked every minute by default so planned posts publish on time.
CONTENT_PLAN_POLL_INTERVAL_MINUTES=1
# Regular scheduled fresh-news publishing is disabled by default; set true to re-enable it later.
ENABLE_SCHEDULED_NEWS=false
PUBLISH_INTERVAL_MINUTES=30

# OpenRouter
# Required for APP_ENV=prod.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4.1-mini
# Dedicated OpenRouter Images API model. Used only when ENABLE_IMAGE_GENERATION=true.
OPENROUTER_IMAGE_MODEL=openai/gpt-image-1-mini
OPENROUTER_IMAGE_QUALITY=low
# Optional: set only if the selected image model supports these parameters.
# OPENROUTER_IMAGE_SIZE=1024x1024
# OPENROUTER_IMAGE_FORMAT=jpeg
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Enable OpenRouter server-side web search for fresh news lookup.
OPENROUTER_ENABLE_WEB_SEARCH=true
OPENROUTER_WEB_SEARCH_ENGINE=auto
OPENROUTER_WEB_SEARCH_MAX_RESULTS=5

# Telegram
# Required for APP_ENV=prod. Copy TELEGRAM_BOT_TOKEN exactly from @BotFather: <bot_id>:<secret>.
# TELEGRAM_CHANNEL_ID is the target channel, for example @channel_name or -1001234567890.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# News and generation
NEWS_TOPIC=technology
NEWS_LANGUAGE=ru
POST_LANGUAGE=ru
MAX_NEWS_ITEMS=5
POST_STYLE=concise
POST_MAX_LENGTH=1000
INCLUDE_SOURCE_LINK=true
INCLUDE_HASHTAGS=true
ENABLE_IMAGE_GENERATION=false
